## Performance Summary

```{r ml-performance-summary}
model_order <- c(
  "Baseline",
  "Ridge Regression",
  "Elastic Net",
  "Tuned SVM",
  "Untuned Random Forest",
  "Tuned Random Forest"
)

metric_order <- c(
  "Accuracy",
  "Balanced accuracy",
  "Cohen's kappa",
  "F1 score",
  "Precision",
  "Sensitivity",
  "Specificity"
)

mean_na <- function(x) {
  if (all(is.na(x))) NA_real_ else mean(x, na.rm = TRUE)
}

sd_na <- function(x) {
  if (all(is.na(x))) NA_real_ else sd(x, na.rm = TRUE)
}

min_na <- function(x) {
  if (all(is.na(x))) NA_real_ else min(x, na.rm = TRUE)
}

max_na <- function(x) {
  if (all(is.na(x))) NA_real_ else max(x, na.rm = TRUE)
}

ml_metrics_summary <- ml_metrics_all %>%
  select(
    model,
    accuracy,
    sensitivity,
    specificity,
    precision,
    f1,
    balanced_accuracy,
    kappa
  ) %>%
  pivot_longer(
    cols = -model,
    names_to = "Metric",
    values_to = "Value"
  ) %>%
  mutate(
    model = factor(model, levels = model_order),
    Metric = recode(
      Metric,
      accuracy = "Accuracy",
      sensitivity = "Sensitivity",
      specificity = "Specificity",
      precision = "Precision",
      f1 = "F1 score",
      balanced_accuracy = "Balanced accuracy",
      kappa = "Cohen's kappa"
    ),
    Metric = factor(Metric, levels = metric_order)
  ) %>%
  group_by(model, Metric) %>%
  summarise(
    M = mean_na(Value),
    SD = sd_na(Value),
    Min = min_na(Value),
    Max = max_na(Value),
    .groups = "drop"
  ) %>%
  arrange(model, Metric)

saveRDS(ml_metrics_summary, "results/ml/ml_metrics_summary.rds")

ml_metrics_summary %>%
  knitr::kable(
    digits = 3,
    caption = "Classification performance of the machine-learning models.",
    col.names = c("Model", "Metric", "M", "SD", "Min", "Max")
  ) %>%
  kableExtra::kable_styling(
    full_width = TRUE,
    bootstrap_options = c("hover")
  )
```

